#!/bin/env ruby

require "pty"
require "io/console"

r, w = IO.pipe

STDERR.reopen w
w.close


ChildWrapperPID = $$


fork do
    begin
        loop do
            IO.select [r]
            buff = r.readpartial(4096)
            File.open "/tmp/test.zsh.log", "a" do |f|
                f.write "#{Time.now.strftime("%H:%M:%S.%L")}(wrapper)[#{ChildWrapperPID}] #{buff}"
            end
        end
    rescue => e
        File.open "/tmp/test.zsh.log", "a" do |f|
            f.write "#{Time.now.strftime("%H:%M:%S.%L")}(logger)[$$] ERROR: #{e.message}\n"
        end
    end
end


tty_in  = IO.for_fd(Integer(ENV.fetch("TTY_IN_FD")))
wsz = tty_in.winsize

tty_out = IO.for_fd(Integer(ENV.fetch("TTY_OUT_FD")), "w")
master, slave = PTY.open
master.winsize = wsz



trap :WINCH do
    STDERR.puts "Received WINCH signal to #{$$}"
    begin
        new_wsz = tty_in.winsize
        if new_wsz != wsz
            wsz = new_wsz
            if master && !master.closed?
                master.winsize = wsz
            end
        end
    rescue => e
        STDERR.puts "trap WINCH error #{$$}, ERROR: #{e.message}"
    end
end

IO.write(ARGV[0], "#{$$} #{slave.path}\n")
slave.close
orig = tty_in.raw!(intr: true)
trap("TERM"){ exit 0 }
trap :INT do 
    STDERR.puts "Received INT signal to #{$$}"
    master.write "\x03" # Ctrl-C
end
trap :TSTP do
    STDERR.puts "Received TSTP signal to #{$$}"
    master.write "\x1A" # Ctrl-Z
end
trap :QUIT do
    STDERR.puts "Received QUIT signal to #{$$}"
    master.write "\x1C" # Ctrl-\
end


class Subst
    attr_reader :file, :time
    def initialize file
        @file = file
        @time = Time.now
        @@filters ||= {}
        @@filters[file] = self
    end
    def self.gsub! str, left
        @@filters ||= {}
        str.insert 0, left
        left.clear
        @@filters.values.sort_by{ |filter| filter.time }.reverse_each do |filter|
            filter.gsub str, left
        end
    end
end


class RbSubst
    def initialize file, filter
        super file
        @filter = filter
        instance_eval filter
    end
end


def registerFilter file
    filter = IO.read(file).strip
    begin
        STDERR.puts "Registering filter: #{filter.inspect} from file: #{file}"
        if file =~ /\.rb$/
            RbSubst.new file, filter
            return
        end
    rescue ArgumentError => e
        STDERR.puts "Error registering filter from file #{file}: #{e.message}"
    rescue RegexpError => e
        STDERR.puts "Invalid regex in filter from file #{file}: #{e.message}"
    end
end


